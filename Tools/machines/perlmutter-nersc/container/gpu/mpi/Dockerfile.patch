# Start from your EXISTING huge image (v3)
# This skips the 10-hour compile time because it's already done!
FROM 359835242613.dkr.ecr.us-east-2.amazonaws.com/warpx-mpi-aws:v3

# Just install the missing SSH packages
# This adds a small "layer" on top of the existing image
RUN apt-get update && \
    apt-get install -y --no-install-recommends \
    openssh-server \
    openssh-client && \
    mkdir -p /var/run/sshd && \
    rm -rf /var/lib/apt/lists/*

# (Optional) Ensure the SSH directory permissions are correct
RUN chmod 755 /var/run/sshd

