#################################
########## DIAGNOSTICS ##########
#################################
diagnostics.diags_names = diag1
diag1.intervals = 200
diag1.diag_type = Full
diag1.fields_to_plot = Ex Ey Ez Bx By Bz rho
diag1.format = openpmd

warpx.reduced_diags_names = KE FieldEnergy

KE.type = ParticleEnergy
KE.intervals = 100

FieldEnergy.type = FieldEnergy
FieldEnergy.intervals = 100
