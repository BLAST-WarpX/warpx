# LWFA — bubble regime — AMR off, no test beam
# n_e = 2e23 m^-3, lambda_p = 23.6 um, lambda_p/c = 79 fs
# a0 = 4 (nonlinear / bubble regime)
# 4000 steps x 0.44 fs/step = 1754 fs ~ 22 plasma periods

max_step = 4000
amr.n_cell =  64  512
amr.max_grid_size = 64
amr.blocking_factor = 32
amr.max_level = 0

geometry.dims = 2
geometry.prob_lo = -30.e-6   -56.e-6
geometry.prob_hi =  30.e-6    12.e-6

boundary.field_lo = pml pml
boundary.field_hi = pml pml

warpx.verbose = 1
warpx.do_dive_cleaning = 0
warpx.use_filter = 1
warpx.cfl = 1.
warpx.do_moving_window = 1
warpx.moving_window_dir = z
warpx.moving_window_v = 1.0
warpx.serialize_initial_conditions = 1

algo.particle_shape = 3

# Plasma electrons only — background plasma, no test beam
particles.species_names = electrons

electrons.species_type = electron
electrons.injection_style = NUniformPerCell
electrons.num_particles_per_cell_each_dim = 2 2
electrons.xmin = -20.e-6
electrons.xmax =  20.e-6
electrons.zmin =  10.e-6
electrons.profile = constant
electrons.density = 2.e23
electrons.momentum_distribution_type = at_rest
electrons.do_continuous_injection = 1

# Ti:Sa 800nm, a0 = 4 (bubble/blowout regime)
lasers.names = laser1
laser1.profile      = Gaussian
laser1.position     = 0. 0. 9.e-6
laser1.direction    = 0. 0. 1.
laser1.polarization = 0. 1. 0.
laser1.e_max        = 16.e12
laser1.profile_waist = 5.e-6
laser1.profile_duration = 15.e-15
laser1.profile_t_peak   = 30.e-15
laser1.profile_focal_distance = 100.e-6
laser1.wavelength = 0.8e-6

diagnostics.diags_names = diag1
diag1.intervals = 200
diag1.diag_type = Full
diag1.fields_to_plot = Ey Ez rho
diag1.format = openpmd
