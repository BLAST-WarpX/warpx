#################################
########## MY CONSTANTS #########
#################################
my_constants.mc2_eV = m_e*clight*clight/q_e

# BEAMS
my_constants.beam_energy_eV = 125.e9
my_constants.beam_gamma = beam_energy_eV/(mc2_eV)
my_constants.beam_N = 2e10
my_constants.sigmax = 516e-9
my_constants.sigmay = 7.7e-9
my_constants.sigmaz = 300e-6
my_constants.muz = 4*sigmaz
my_constants.nmacropart = 1e5
my_constants.emitx       = 0. #5*micro
my_constants.emity       = 0. #35*nano
my_constants.dux         = emitx / sigmax
my_constants.duy         = emity / sigmay

# BOX
my_constants.Lx = 64*sigmax
my_constants.Ly = 64*sigmay
my_constants.Lz = 16*sigmaz

my_constants.nx = 128
my_constants.ny = 128
my_constants.nz = 32

# TIME
my_constants.T = 0.5*Lz/clight
my_constants.dt = T / nz

#################################
####### GENERAL PARAMETERS ######
#################################
stop_time = T
amr.n_cell = nx ny nz
geometry.dims = 3
geometry.prob_lo = -0.5*Lx -0.5*Ly -0.5*Lz
geometry.prob_hi =  0.5*Lx  0.5*Ly  0.5*Lz

#################################
######## BOUNDARY CONDITION #####
#################################
boundary.field_lo = open open open
boundary.field_hi = open open open
boundary.particle_lo = Absorbing Absorbing Absorbing
boundary.particle_hi = Absorbing Absorbing Absorbing

#################################
############ NUMERICS ###########
#################################
warpx.do_electrostatic = relativistic
warpx.const_dt = dt
warpx.grid_type = collocated
algo.particle_shape = 3
algo.particle_pusher = vay
warpx.poisson_solver = fft
warpx.use_2d_slices_fft_solver = 0
amr.max_level = 0
amr.ref_ratio_vect = 2 2 2
warpx.fine_tag_hi = -3*sigmax -3*sigmay -3*sigmaz
warpx.fine_tag_lo =  3*sigmax 3*sigmay 3*sigmaz

#################################
########### PARTICLES ###########
#################################
particles.species_names = beam1 virtual_photons1 beam2 virtual_photons2 pho1 pho2 ele_bh pos_bh ele_ll pos_ll ele_bw pos_bw
particles.photon_species = virtual_photons1 virtual_photons2 pho1 pho2

# beam 1
beam1.do_qed_virtual_photons = 1
beam1.qed_virtual_photon_species_name = virtual_photons1
beam1.momentum_distribution_type = gaussian
beam1.uz_m = beam_gamma
beam1.uy_m = 0.0
beam1.ux_m = 0.0
beam1.ux_th = dux
beam1.uy_th = duy
beam1.uz_th = 0
beam1.do_not_push = 0
beam1.species_type = electron
beam1.injection_style = gaussian_beam
beam1.x_rms = sigmax
beam1.y_rms = sigmay
beam1.z_rms = sigmaz
beam1.x_m = 0
beam1.y_m = 0
beam1.z_m = -muz
beam1.npart = nmacropart
beam1.q_tot = -beam_N*q_e
beam1.z_cut = 4
beam1.do_qed_quantum_sync = 1
beam1.qed_quantum_sync_phot_product_species = pho1



# Virtual photons 1
virtual_photons1.virtual_photons_min_energy = m_e*clight*clight # has to be small enough
virtual_photons1.sampling_factor = 2
virtual_photons1.species_type = photon
virtual_photons1.injection_style = none
virtual_photons1.do_not_push = 1


# beam 2
beam2.do_qed_virtual_photons = 1
beam2.qed_virtual_photon_species_name = virtual_photons2
beam2.momentum_distribution_type = gaussian
beam2.uz_m = -beam_gamma
beam2.uy_m = 0.0
beam2.ux_m = 0.0
beam2.ux_th = dux
beam2.uy_th = duy
beam2.uz_th = 0
beam2.do_not_push = 0
beam2.species_type = positron
beam2.injection_style = gaussian_beam
beam2.x_rms = sigmax
beam2.y_rms = sigmay
beam2.z_rms = sigmaz
beam2.x_m = 0
beam2.y_m = 0
beam2.z_m = muz
beam2.npart = nmacropart
beam2.q_tot = beam_N*q_e
beam2.z_cut = 4
beam2.do_qed_quantum_sync = 1
beam2.qed_quantum_sync_phot_product_species = pho2


# Virtual photons 2
virtual_photons2.virtual_photons_min_energy = m_e*clight*clight # has to be small enough
virtual_photons2.sampling_factor = 2
virtual_photons2.species_type = photon
virtual_photons2.injection_style = none
virtual_photons2.do_not_push = 1

