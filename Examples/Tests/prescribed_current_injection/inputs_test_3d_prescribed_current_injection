# Regression test: prescribed current injection into a single-turn coil
#
# Geometry: single-turn copper coil centred in a 3-D domain.
#   Inner radius   R_i = 0.100 m
#   Outer radius   R_o = 0.115 m
#   Axial extent   z in [0.09, 0.15] m  (coil height = 0.06 m)
#   Domain         [-0.20, 0.20]^2 x [0.00, 0.24] m   (80 x 80 x 48 cells, 5 mm)
#
# Drive: prescribe the RLC-discharge current waveform at the coil gap via
#   warpx.current_injection.*  (new feature under test).
#   The waveform file current_profile.txt is generated by the helper script
#   in this directory and tabulates the open-loop RLC formula up to 150 ns.
#
# CI smoke test: run 50 steps and verify the simulation completes without
#   crashing and produces finite field values (analysis.py).

amr.n_cell          = 80  80  48
amr.max_grid_size   = 64
amr.max_level       = 0

geometry.dims       = 3
geometry.prob_lo    = -0.20  -0.20   0.00
geometry.prob_hi    =  0.20   0.20   0.24

warpx.cfl           = 0.9
warpx.pml_ncell     = 4

max_step            = 50        # smoke test: just verify no crash

algo.em_solver_medium           = macroscopic
algo.macroscopic_sigma_method   = backwardeuler

# --- Physical constants ---
my_constants.sigma_cu   = 6.0e7   # S/m  copper conductivity
my_constants.R_i        = 0.100   # m    coil inner radius
my_constants.R_o        = 0.115   # m    coil outer radius
my_constants.x_in_g     = 0.010   # m    half-gap width  (2 cells)
my_constants.x_out_g    = 0.025   # m    outer lead half-width  (5 cells)
my_constants.y_out_g    = -0.112250   # m   -sqrt(R_o^2-x_out_g^2)
my_constants.y_in_g     = -0.099499   # m   -sqrt(R_i^2-x_in_g^2)  (gap meets inner radius)
my_constants.y_bot      = -0.142250   # m   y_out_g - 0.030 (lead base)
my_constants.z_coil_lo  = 0.09    # m
my_constants.z_coil_hi  = 0.15    # m
my_constants.A_gap      = 2.565e-3   # m^2  (y_in_g - y_bot) * (z_coil_hi - z_coil_lo)

# Copper ring + radial leads; gap (|x|<x_in_g, y<0) stays vacuum
macroscopic.sigma_function(x,y,z) = "sigma_cu * (z>=z_coil_lo)*(z<=z_coil_hi) * ( (x*x+y*y>=R_i*R_i)*(x*x+y*y<=R_o*R_o)*(1.0-(abs(x)<x_in_g)*(y<0.0)) + (abs(x)>=x_in_g)*(abs(x)<=x_out_g)*(y>=y_bot)*(y<=y_out_g) )"
macroscopic.epsilon_function(x,y,z) = "epsilon0"
macroscopic.mu_function(x,y,z)      = "mu0"

# --- Prescribed current injection (feature under test) ---
warpx.current_injection         = 1
warpx.current_injection.file    = current_profile.txt

warpx.current_injection.n_pairs                   = 1
warpx.current_injection.pair_0.drive.xlo          = -x_in_g
warpx.current_injection.pair_0.drive.xhi          =  x_in_g
warpx.current_injection.pair_0.drive.ylo          = y_bot
warpx.current_injection.pair_0.drive.yhi          = y_in_g
warpx.current_injection.pair_0.drive.zlo          = z_coil_lo
warpx.current_injection.pair_0.drive.zhi          = z_coil_hi
warpx.current_injection.pair_0.drive.A            = A_gap
warpx.current_injection.pair_0.drive.dir          = 0          # Jx

# --- Single diagnostic at the end of the run ---
diagnostics.diags_names = diag1
diag1.intervals         = -1      # output only at the final step
diag1.diag_type         = Full
diag1.fields_to_plot    = Bz
diag1.format            = plotfile
