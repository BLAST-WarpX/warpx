# Geometry
geometry.coord_sys = 0
geometry.dims = 1
geometry.is_periodic = 1
geometry.prob_hi = 0.0070164904795607845
geometry.prob_lo = 0

amr.max_grid_size = 1024
amr.max_level = 0
amr.n_cell = 1024

# Time stepping
warpx.const_dt = 2e-11
max_step = 10000

# Boundary conditions
boundary.field_hi = periodic
boundary.field_lo = periodic
boundary.particle_hi = periodic
boundary.particle_lo = periodic

# Algorithm
algo.maxwell_solver = hybrid
algo.evolve_scheme = theta_implicit_hybrid #explicit
algo.particle_shape = 1
algo.current_deposition = direct

# Hybrid PIC model parameters
hybrid_pic_model.elec_temp = 0.002554994753458765
hybrid_pic_model.n0_ref = 6.01476103392597e+23
hybrid_pic_model.plasma_resistivity(rho,J) = 1e-07
hybrid_pic_model.substeps = 1 #unused for implicit

# Implicit evolve parameters
implicit_evolve.nonlinear_solver = newton
implicit_evolve.theta = 0.5
implicit_evolve.max_particle_iterations = 21
implicit_evolve.particle_tolerance = 1e-10

# Newton solver
newton.verbose = 2
newton.max_iterations = 20
newton.relative_tolerance = 1e-06
newton.absolute_tolerance = 0.0
newton.require_convergence = 0

# GMRES linear solver (no preconditioning)
amrex_gmres.verbose_int = 1
amrex_gmres.max_iterations = 100
amrex_gmres.relative_tolerance = 1e-04
amrex_gmres.absolute_tolerance = 0.0
jacobian.pc_type = none

# Species
particles.species_names = ions
ions.charge = q_e
ions.density = 6.01476103392597e+23
ions.initialize_self_fields = 0
ions.injection_style = nrandompercell
ions.mass = 9.1093837139e-29
ions.momentum_distribution_type = gaussian
ions.num_particles_per_cell = 1024
ions.profile = constant
ions.ux_m = 0.0
ions.ux_th = 7.071067811865475e-06
ions.uy_m = 0.0
ions.uy_th = 7.071067811865475e-06
ions.uz_m = 0.0
ions.uz_th = 7.071067811865475e-06

# External magnetic field
warpx.B_ext_grid_init_style = parse_b_ext_grid_function
warpx.Bx_external_grid_function(x,y,z) = 0.0
warpx.By_external_grid_function(x,y,z) = 0.0
warpx.Bz_external_grid_function(x,y,z) = 0.25

my_constants.clight = 299792458
my_constants.epsilon0 = 8.8541878188000004e-12
my_constants.kb = 1.3806490000000001e-23
my_constants.m_e = 9.1093837138999998e-31
my_constants.m_p = 1.6726219259499999e-27
my_constants.m_u = 1.6605390689199999e-27
my_constants.mu0 = 1.2566370612685e-06
my_constants.pi = 3.1415926535897931
my_constants.q_e = 1.6021766339999999e-19

# Diagnostics
diagnostics.diags_names = field_diag
field_diag.diag_type = Full
field_diag.fields_to_plot = Bx By Bz Ex Ey Ez jx_displacement jy_displacement jz_displacement
field_diag.format = openpmd
field_diag.intervals = 10000
field_diag.openpmd_backend = h5
field_diag.species = ions

warpx.reduced_diags_names = par_field_data
par_field_data.intervals = 10
par_field_data.path = diags/
par_field_data.probe_geometry = Line
par_field_data.resolution = 1023
par_field_data.type = FieldProbe
par_field_data.z1_probe = 0.0070164904795607845
par_field_data.z_probe = 0

